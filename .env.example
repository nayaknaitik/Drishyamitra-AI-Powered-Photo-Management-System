## Drishyamitra environment variables (example)

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me

# Auth (JWT)
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Database (PostgreSQL default; SQLite fallback)
DATABASE_URL=postgresql+psycopg2://drishyamitra:drishyamitra@postgres:5432/drishyamitra
SQLITE_FALLBACK_PATH=./drishyamitra.db

# Redis (optional)
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Uploads
UPLOAD_ROOT=/app/uploads
MAX_CONTENT_LENGTH_MB=25

# Groq (LLM)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App base URL (for links)
PUBLIC_BASE_URL=http://localhost

